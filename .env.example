# -----------------------------------------------------------------------------
# Database Configuration
# Prisma supports PostgreSQL connection URLs.
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/scm_db?schema=public"

# -----------------------------------------------------------------------------
# Clerk Authentication Configuration
# Sign up at https://clerk.com to get your keys.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk URL redirects (already configured in Next.js middleware)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# -----------------------------------------------------------------------------
# Anthropic Claude AI Configuration
# Sign up at https://console.anthropic.com to get an API key for SCM intelligence.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."
